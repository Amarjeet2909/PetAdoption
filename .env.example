# ══════════════════════════════════════════════════════════════
# PetAdoption — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env to Git.
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL (Docker local dev) ─────────────────────────────
POSTGRES_PASSWORD=YourLocalPassword123

# ── JWT ───────────────────────────────────────────────────────
JWT_KEY=your_super_secret_jwt_key_min_32_characters_long
JWT_ISSUER=PetAdoption.API
JWT_AUDIENCE=PetAdoption.Client

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email ─────────────────────────────────────────────────────
EMAIL_SENDER_EMAIL=your@gmail.com
EMAIL_SENDER_PASSWORD=your_gmail_app_password

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com